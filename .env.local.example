# Copie este arquivo para .env.local (NUNCA commite o .env.local).
#   cp .env.local.example .env.local

# Access Token do Mercado Pago — SOMENTE servidor. Nunca prefixe com NEXT_PUBLIC_.
# Teste (sandbox): comeca com TEST-...   |   Producao: comeca com APP_USR-...
# Onde pegar: https://www.mercadopago.com.br/developers/panel/app > sua aplicacao > Credenciais
MERCADO_PAGO_ACCESS_TOKEN=TEST-coloque-seu-token-aqui

# URL publica do site (usada nas back_urls do checkout).
# Dev local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Producao (Vercel): defina nas Environment Variables do projeto, ex.:
# NEXT_PUBLIC_SITE_URL=https://overberry.vercel.app

# --- Supabase (registro de pedidos) — SOMENTE servidor ---
# Painel do Supabase > Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Service role key: bypassa RLS. NUNCA prefixe com NEXT_PUBLIC_, nunca use no client.
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui

# --- Webhook Mercado Pago ---
# Secret gerado ao cadastrar o webhook no painel do MP (Suas integracoes > Webhooks).
# Vazio em desenvolvimento: assinatura e PULADA com warning no console.
# Em producao e OBRIGATORIO — sem ele o webhook rejeita tudo com 401.
MERCADO_PAGO_WEBHOOK_SECRET=
