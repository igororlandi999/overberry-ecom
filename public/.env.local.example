# Copie este arquivo para .env.local (NUNCA commite o .env.local).
#   cp .env.local.example .env.local

# Access Token do Mercado Pago — SOMENTE servidor. Nunca prefixe com NEXT_PUBLIC_.
# Teste (sandbox): comeca com TEST-...   |   Producao: comeca com APP_USR-...
# Onde pegar: https://www.mercadopago.com.br/developers/panel/app > sua aplicacao > Credenciais
MERCADO_PAGO_ACCESS_TOKEN=TEST-coloque-seu-token-aqui

# URL publica do site (usada nas back_urls do checkout).
# Dev local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Producao (Vercel): defina nas Environment Variables do projeto, ex.:
# NEXT_PUBLIC_SITE_URL=https://overberry.vercel.app
